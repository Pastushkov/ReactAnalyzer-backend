{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Run ReactAnalyzerBE",
      "type": "shell",
      "command": "${workspaceFolder}/venv/bin/python -m uvicorn app.main:app --reload",
      "windows": {
        "command": "${workspaceFolder}\\venv\\Scripts\\python.exe -m uvicorn app.main:app --reload"
      },
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "presentation": {
        "reveal": "always",
        "panel": "new",
        "focus": true
      },
      "problemMatcher": []
    }
  ]
}
